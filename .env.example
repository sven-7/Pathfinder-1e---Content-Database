# Copy this to .env and fill in real values.
# .env is gitignored — never commit real credentials.

# PostgreSQL connection (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://pf1e:changeme@localhost:5432/pf1e_users

# Postgres password used by docker-compose
PG_PASSWORD=changeme

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-replace-with-random-hex-string

# Token lifetime in minutes (default: 10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
